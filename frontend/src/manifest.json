{
    "name": "百宝箱",
    "appid": "",
    "description": "多功能开发者工具集",
    "versionName": "1.0.0",
    "versionCode": "100",
    "transformPx": false,
    "app-plus": {
        "usingComponents": true,
        "nvueStyleCompiler": "uni-app",
        "compilerVersion": 3,
        "splashscreen": {
            "alwaysShowBeforeRender": true,
            "waiting": true,
            "autoclose": true,
            "delay": 0
        },
        "modules": {},
        "distribute": {
            "android": {
                "permissions": []
            },
            "ios": {},
            "sdkConfigs": {}
        }
    },
    "quickapp": {},
    "mp-weixin": {
        "appid": "",
        "setting": {
            "urlCheck": false,
            "es6": true,
            "postcss": true,
            "minified": true
        },
        "usingComponents": true
    },
    "h5": {
        "devServer": {
            "port": 5173,
            "proxy": {
                "/api": {
                    "target": "http://localhost:8080",
                    "changeOrigin": true
                }
            }
        }
    },
    "uniStatistics": {
        "enable": false
    },
    "vueVersion": "3"
}
